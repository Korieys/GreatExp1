rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles - Users can read/write their own profiles, Admins manage all
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Blog posts - Public readable, Admin writable
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Practitioners directory - Public readable, Admin writable
    match /practitioners/{practitionerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services directory - Public readable, Admin writable
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Appointments - Users read/manage their own. Admins manage all.
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Site Content CMS - Public readable for the frontend, Admin writable
    match /siteContent/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact form submissions - Public can submit, Admins can read/manage
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Newsletter Subscribers - Public can subscribe
    match /subscribers/{subscriberId} {
    	allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
