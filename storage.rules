rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Uses Firebase Storage cross-service rule to check the user's role in Firestore
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Blog images - Public readable, Admin writable
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Practitioner images - Public readable, Admin writable
    match /practitioners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services assets - Public readable, Admin writable
    match /services/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profile uploads (avatars)
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Appointment Documents (Insurance cards, IDs, Intake forms)
    match /appointments/{userId}/{allPaths=**} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Default deny for anything else to prevent unauthorized uploads
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
